---
const year = new Date().getFullYear();

const footerLinks = [
  {
    title: "Servicios",
    links: [
      { href: "/#servicios", label: "Páginas Web" },
      { href: "/#servicios", label: "E-commerce" },
      { href: "/#servicios", label: "Software a la Medida" },
      { href: "/#servicios", label: "Apps Móviles" },
    ],
  },
  {
    title: "Enlaces",
    links: [
      { href: "/nosotros", label: "Nosotros" },
      { href: "/#portafolio", label: "Portafolio" },
      { href: "/#proceso", label: "Nuestro Proceso" },
    ],
  },
  {
    title: "Contacto",
    links: [
      {
        href: "https://wa.me/584262590251",
        label: "WhatsApp Venezuela",
        external: true,
      },
      {
        href: "https://wa.me/573219646346",
        label: "WhatsApp Colombia",
        external: true,
      },
    ],
  },
];
---

<footer class="bg-zinc-950 border-t border-zinc-900/80 text-zinc-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12"
    >
      <div>
        <a
          href="/"
          class="inline-block mb-4"
          aria-label="Grupo Rincon - Inicio"
        >
          <img
            src="/Logo/Logo blanco.png"
            alt="Grupo Rincon"
            class="h-10 w-auto object-contain"
            loading="lazy"
          />
        </a>
        <p class="text-zinc-500 text-sm leading-relaxed max-w-xs mb-6">
          Desarrollamos el software y la página web que tu negocio necesita para
          vender más y operar mejor.
        </p>
        <div class="flex items-center gap-4">
          <a
            href="https://www.instagram.com/gruporinconve/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-zinc-400 hover:text-white transition-colors"
            aria-label="Instagram"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>

      {
        footerLinks.map((group) => (
          <div>
            <h3 class="font-bold text-white mb-5 text-xs uppercase tracking-widest">
              {group.title}
            </h3>
            <ul class="space-y-3">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener noreferrer" : undefined}
                    class="text-zinc-400 hover:text-white text-sm transition-colors duration-200 cursor-pointer"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-16 pt-8 border-t border-zinc-900/80">
      <div
        class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-zinc-500"
      >
        <p>&copy; {year} Grupo Rincon. Todos los derechos reservados.</p>
        <div
          class="flex items-center gap-4 text-xs font-semibold tracking-wider"
        >
          <span>gruporincon.com.ve</span>
          <span class="text-zinc-800">|</span>
          <span>gruporincon.com.co</span>
        </div>
      </div>
      <p
        class="mt-4 text-xs text-zinc-600 text-center md:text-left leading-relaxed"
      >
        Desarrollo de software en Caracas, Maracaibo, Valencia, Bogotá,
        Medellín, Cali, Cartagena y toda Latinoamérica.
      </p>
    </div>
  </div>
</footer>
