---
const stats = [
  { value: "+10", label: "Años de experiencia" },
  { value: "+100", label: "Proyectos exitosos" },
  { value: "8", label: "Países con clientes" },
];
---

<section class="bg-zinc-950/20 border-y border-zinc-900/60">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-zinc-800/60 reveal">
      {
        stats.map((stat) => (
          <div class="flex flex-col items-center justify-center text-center px-4 py-8 sm:py-0">
            <span class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight font-display bg-gradient-to-b from-white to-secondary-300 bg-clip-text text-transparent">
              {stat.value}
            </span>
            <span class="text-xs sm:text-sm text-zinc-500 uppercase tracking-widest font-bold mt-3">
              {stat.label}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>

