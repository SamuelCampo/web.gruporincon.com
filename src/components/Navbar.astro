---
const links = [
  { href: "/", label: "Inicio" },
  { href: "/#servicios", label: "Servicios" },
  { href: "/#proceso", label: "Proceso" },
  { href: "/#portafolio", label: "Portafolio" },
  { href: "/nosotros", label: "Nosotros" },
];
---

<header class="fixed top-4 left-4 right-4 z-50 max-w-7xl mx-auto">
  <div
    id="navbar-container"
    class="glass-panel rounded-full px-6 py-3 shadow-lg shadow-black/30 transition-colors duration-300"
  >
    <nav
      class="flex items-center justify-between"
      aria-label="Navegación principal"
    >
      <a
        href="/"
        class="flex items-center gap-2 cursor-pointer"
        aria-label="Grupo Rincon - Inicio"
      >
        <img
          src="/Logo/Logo blanco.png"
          alt="Grupo Rincon"
          class="max-w-36 w-auto object-contain"
          loading="eager"
        />
      </a>

      <!-- Desktop Links -->
      <div class="hidden lg:flex items-center gap-8">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-md font-semibold text-zinc-300 hover:text-white transition-colors duration-200 cursor-pointer"
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <!-- Desktop Button -->
      <div class="hidden lg:block">
        <a
          href="https://wa.me/584262590251"
          target="_blank"
          rel="noopener noreferrer"
          class="glow-btn cursor-pointer inline-flex items-center gap-2 bg-secondary-500 hover:bg-secondary-600 text-white px-5 py-2 rounded-full text-md font-bold tracking-wide transition-all duration-300"
        >
          <svg
            class="w-3.5 h-3.5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          Contacto
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="menu-toggle"
        class="lg:hidden p-2 rounded-full text-zinc-300 hover:text-white hover:bg-white/10 transition-colors cursor-pointer"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg
          id="menu-icon"
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </nav>

    <!-- Mobile Dropdown Menu -->
    <div
      id="mobile-menu"
      class="hidden lg:hidden mt-4 pt-4 border-t border-white/5"
      role="navigation"
      aria-label="Menú móvil"
    >
      <div class="flex flex-col gap-3">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-sm font-medium text-zinc-300 hover:text-white transition-colors px-3 py-2 rounded-xl hover:bg-white/5 cursor-pointer"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="https://wa.me/584161234567"
          target="_blank"
          rel="noopener noreferrer"
          class="glow-btn cursor-pointer inline-flex items-center justify-center gap-2 bg-secondary-500 hover:bg-secondary-600 text-white px-5 py-3 rounded-full text-sm font-bold tracking-wide transition-all mt-2"
        >
          <svg
            class="w-4 h-4"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const navbarContainer = document.getElementById("navbar-container");

  const updateNavbar = () => {
    const isScrolled = window.scrollY > 50;
    const isMenuOpen = toggle?.getAttribute("aria-expanded") === "true";

    if (isScrolled || isMenuOpen) {
      navbarContainer?.classList.add(
        "backdrop-blur-md",
        "border",
        "border-white/10"
      );
      
      if (isMenuOpen) {
        navbarContainer?.classList.add("bg-black");
        navbarContainer?.classList.remove("bg-zinc-950/95");
      } else {
        navbarContainer?.classList.add("bg-zinc-950/95");
        navbarContainer?.classList.remove("bg-black");
      }
      
      navbarContainer?.classList.remove("glass-panel");
    } else {
      navbarContainer?.classList.remove(
        "bg-zinc-950/95",
        "bg-black",
        "backdrop-blur-md",
        "border",
        "border-white/10"
      );
      navbarContainer?.classList.add("glass-panel");
    }
  };

  window.addEventListener("scroll", updateNavbar);

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      menu.classList.toggle("hidden");
      
      if (!expanded) {
        navbarContainer?.classList.remove("rounded-full");
        navbarContainer?.classList.add("rounded-2xl");
      } else {
        navbarContainer?.classList.remove("rounded-2xl");
        navbarContainer?.classList.add("rounded-full");
      }
      updateNavbar();
    });
    document.querySelectorAll("#mobile-menu a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
        navbarContainer?.classList.remove("rounded-2xl");
        navbarContainer?.classList.add("rounded-full");
        updateNavbar();
      });
    });
  }
</script>
