---

---

<section
  class="relative min-h-screen flex items-center overflow-hidden bg-black"
>
  <!-- ══ VIDEO BACKGROUND ══════════════════════════════════════════════════ -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover"
    autoplay
    loop
    muted
    playsinline
    preload="auto"
    aria-hidden="true"
  >
    <source src="/hero/Video 1.mp4" type="video/mp4" />
  </video>

  <!-- ══ OVERLAYS ══════════════════════════════════════════════════════════ -->
  <!-- Dark veil so text is always readable -->
  <div class="absolute inset-0 bg-black/55" aria-hidden="true"></div>
  <!-- Bottom fade to match next section -->
  <div
    class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-black to-transparent"
    aria-hidden="true"
  >
  </div>
  <!-- Subtle brand-blue radial glow in top-left -->
  <div
    class="absolute top-[-5%] left-[-5%] w-[55%] h-[55%] rounded-full bg-secondary-500/10 blur-[140px] pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <!-- ══ CONTENT ════════════════════════════════════════════════════════════ -->
  <div
    class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-28 lg:pt-44 lg:pb-36"
  >
    <div class="max-w-4xl mx-auto text-center">
      <!-- Badge -->
      <div
        class="inline-flex items-center gap-2 bg-white/5 border border-white/10 backdrop-blur-sm px-4 py-1.5 rounded-full mb-8 reveal"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-secondary-400 animate-pulse"
        ></span>
        <span
          class="text-xs font-semibold text-zinc-300 tracking-widest uppercase font-display"
          >+10 años impulsando PYMEs</span
        >
      </div>

      <!-- Headline -->
      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.05] tracking-tight reveal font-display"
      >
        Desarrollamos el software<br class="hidden sm:block" />
        y la página web que tu<br class="hidden sm:block" />
        negocio necesita para
        <span
          class="bg-gradient-to-r from-secondary-300 via-blue-300 to-secondary-400 bg-clip-text text-transparent"
        >
          vender más y operar mejor.
        </span>
      </h1>

      <!-- Subheadline -->

      <!-- CTAs -->
      <div
        class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 reveal"
      >
        <a
          href="https://wa.me/584262590251"
          target="_blank"
          rel="noopener noreferrer"
          class="glow-btn cursor-pointer inline-flex items-center gap-2.5 bg-secondary-500 hover:bg-secondary-600 text-white px-8 py-4 rounded-full text-sm font-bold tracking-wide transition-all duration-300 shadow-lg shadow-secondary-500/30"
        >
          <svg
            class="w-4 h-4"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          Hablar con un experto
        </a>
        <a
          href="#servicios"
          class="cursor-pointer inline-flex items-center gap-2 border border-white/20 hover:border-white/40 text-white/80 hover:text-white px-8 py-4 rounded-full text-sm font-semibold tracking-wide transition-all duration-300 backdrop-blur-sm bg-white/5 hover:bg-white/10"
        >
          Ver nuestros servicios
          <svg
            class="w-3.5 h-3.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
      </div>

      <p
        class="mt-5 text-xs text-base md:text-lg text-white tracking-wide reveal"
      >
        Cuéntanos tu idea hoy mismo.
      </p>
    </div>

    <!-- ── Scroll indicator ──────────────────────────────────────────────── -->
    <div
      class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40 hover:opacity-80 transition-opacity"
      aria-hidden="true"
    >
      <div
        class="w-px h-10 bg-gradient-to-b from-transparent via-white to-transparent animate-pulse"
      >
      </div>
      <svg
        class="w-3 h-3 text-white"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
  </div>
</section>
