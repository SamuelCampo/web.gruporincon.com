---
const pillars = [
  {
    title: "Te entendemos de verdad",
    description: "No solo escuchamos tu idea, nos sumergimos en tu negocio para convertirla en una solución que realmente resuelve.",
    icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
    link: "Historias de colaboración"
  },
  {
    title: "Agilidad que marca la diferencia",
    description: "Iteramos, probamos y mejoramos contigo en cada paso para que llegues primero y mejor.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    link: "Historias de velocidad"
  },
  {
    title: "Enfocados en resultados",
    description: "Diseñamos pensando en tus usuarios y en tus objetivos de negocio para generar impacto medible.",
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    link: "Historias de impacto"
  },
  {
    title: "Te acompañamos siempre",
    description: "Más allá del lanzamiento, estamos contigo para optimizar, escalar y asegurar el éxito a largo plazo.",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
    link: "Historias de crecimiento"
  },
];
---

<section id="por-que-elegirnos" class="bg-[#030712] py-20 lg:py-32 relative overflow-hidden">
  <!-- Glowing background ambient -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-secondary-600/10 blur-[150px] pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20 lg:mb-32 reveal">
      <span class="inline-block text-[10px] sm:text-xs font-bold text-blue-500/80 uppercase tracking-widest bg-secondary-900/40 border border-secondary-500/20 px-5 py-2 rounded-full font-display mb-8">
        POR QUÉ ELEGIRNOS
      </span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white font-display tracking-tight mb-6">
        Tu éxito es nuestro <span class="text-blue-500 relative inline-block">código<span class="absolute -right-3 top-1 bottom-1 w-1.5 bg-blue-500/80 shadow-[0_0_10px_rgba(59,130,246,1)] animate-pulse"></span></span>
      </h2>
      <p class="text-zinc-400 text-sm sm:text-base lg:text-lg leading-relaxed max-w-2xl mx-auto">
        Más que tecnología, somos tu aliado para construir, lanzar<br class="hidden sm:block" /> y escalar soluciones digitales que generan impacto real.
      </p>
    </div>

    <!-- Grid Container with relative positioning for central graphics -->
    <div class="relative">
      
      <!-- Center Infinity Symbol & Dashed Lines (Desktop only) -->
      <div class="hidden lg:flex absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-[300px] items-center justify-center pointer-events-none z-0">
        
        <!-- Dashed connecting lines container -->
        <div class="absolute inset-0 w-full h-full">
          <!-- Top Left -->
          <svg class="absolute top-[10%] left-[25%] w-[25%] h-[40%]" viewBox="0 0 100 100" preserveAspectRatio="none">
            <path d="M0,0 Q 50,0 100,100" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="3 3" fill="none" />
            <circle cx="0" cy="0" r="3" fill="#60a5fa" />
          </svg>
          <!-- Top Right -->
          <svg class="absolute top-[10%] right-[25%] w-[25%] h-[40%]" viewBox="0 0 100 100" preserveAspectRatio="none">
            <path d="M100,0 Q 50,0 0,100" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="3 3" fill="none" />
            <circle cx="100" cy="0" r="3" fill="#60a5fa" />
          </svg>
          <!-- Bottom Left -->
          <svg class="absolute bottom-[10%] left-[25%] w-[25%] h-[40%]" viewBox="0 0 100 100" preserveAspectRatio="none">
            <path d="M0,100 Q 50,100 100,0" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="3 3" fill="none" />
            <circle cx="0" cy="100" r="3" fill="#60a5fa" />
          </svg>
          <!-- Bottom Right -->
          <svg class="absolute bottom-[10%] right-[25%] w-[25%] h-[40%]" viewBox="0 0 100 100" preserveAspectRatio="none">
            <path d="M100,100 Q 50,100 0,0" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="3 3" fill="none" />
            <circle cx="100" cy="100" r="3" fill="#60a5fa" />
          </svg>
        </div>

        <!-- Glowing Infinity Symbol -->
        <svg class="relative z-10 w-[240px] text-blue-500 overflow-visible opacity-90 drop-shadow-[0_0_20px_rgba(59,130,246,0.6)]" viewBox="0 0 200 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M 50 50 C 10 10, 10 90, 50 50 C 90 10, 110 90, 150 50 C 190 10, 190 90, 150 50 C 110 10, 90 90, 50 50 Z" stroke="url(#infinity-grad)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          <defs>
            <linearGradient id="infinity-grad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#93c5fd" />
              <stop offset="50%" stop-color="#2563eb" />
              <stop offset="100%" stop-color="#93c5fd" />
            </linearGradient>
          </defs>
        </svg>

      </div>

      <!-- Pillars Content Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-y-16 lg:gap-y-40 lg:gap-x-48 relative z-10">
        {
          pillars.map((pilar, i) => (
            <div
              class="group flex flex-col sm:flex-row gap-6 reveal cursor-pointer"
              style={`animation-delay: ${i * 100}ms`}
            >
              <!-- Icon -->
              <div class="flex-shrink-0">
                <div class="w-14 h-14 rounded-full border border-blue-900/50 flex items-center justify-center bg-black shadow-[0_0_15px_rgba(30,58,138,0.3)] group-hover:shadow-[0_0_25px_rgba(59,130,246,0.5)] group-hover:border-blue-500/80 transition-all duration-300">
                  <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={pilar.icon} />
                  </svg>
                </div>
              </div>
              
              <!-- Text -->
              <div class="flex-1 pt-1 pb-4">
                <h3 class="text-xl lg:text-[22px] font-bold text-white mb-3 tracking-tight font-display">{pilar.title}</h3>
                <p class="text-zinc-400 text-sm leading-relaxed mb-5">{pilar.description}</p>
                

              </div>
            </div>
          ))
        }
      </div>

    </div>
  </div>
</section>
