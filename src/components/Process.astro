---
const steps = [
  {
    number: "01",
    title: "Consultoría Inicial",
    description: "Analizamos a fondo las necesidades y los objetivos de tu negocio para trazar una ruta.",
    image: "/process/consultoria.png"
  },
  {
    number: "02",
    title: "Diseño UI/UX",
    description: "Modelamos visualmente tu plataforma. Creamos interfaces modernas e intuitivas.",
    image: "/process/UI UX.png"
  },
  {
    number: "03",
    title: "Desarrollo Experto",
    description: "Construimos tu plataforma escribiendo código limpio, seguro y escalable.",
    image: "/process/desarrollo.png"
  },
  {
    number: "04",
    title: "Pruebas y Lanzamiento",
    description: "Sometemos el proyecto a rigurosos controles de calidad y rendimiento antes de publicarlo.",
    image: "/process/lanzamiento.png"
  },
];
---

<section id="proceso" class="bg-gradient-to-b from-[#f8f9ff] to-white py-20 lg:py-32 relative overflow-hidden">
  <!-- Abstract background decorative elements -->
  <div class="absolute top-0 right-0 w-full h-full opacity-40 pointer-events-none" style="background: radial-gradient(circle at 80% -20%, rgba(59, 130, 246, 0.15) 0%, transparent 50%);"></div>
  <div class="absolute top-40 right-20 w-96 h-96 bg-blue-100 rounded-full blur-[100px] opacity-30 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-16 lg:mb-20">
      <div class="max-w-2xl reveal">
        <span class="inline-block text-xs font-bold text-blue-600 uppercase tracking-widest bg-blue-50 px-3.5 py-1.5 rounded-full font-display mb-6 border border-blue-100">
          Metodología de Trabajo
        </span>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-slate-900 leading-[1.1] font-display tracking-tight">
          De la idea al código <br class="hidden sm:block" /> en 4 pasos.
        </h2>
      </div>
      <div class="max-w-md lg:pb-3 reveal" style="animation-delay: 100ms;">
        <p class="text-slate-600 text-lg leading-relaxed">
          Un proceso claro, colaborativo y eficiente para transformar tus ideas en soluciones digitales sólidas y escalables.
        </p>
      </div>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        steps.map((step, i) => (
          <div 
            class="bg-slate-900 rounded-[2rem] p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_20px_40px_rgb(0,0,0,0.12)] transition-all duration-500 border border-slate-800 flex flex-col relative group min-h-[420px] reveal align-bottom"
            style={`animation-delay: ${i * 100 + 200}ms`}
          >
            <!-- Background Image -->
            <div class="absolute inset-0 z-0 overflow-hidden rounded-[2rem]">
              <img 
                src={step.image} 
                alt="" 
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80" 
              />
              <!-- Gradient Overlay for contrast -->
              <div class="absolute inset-0 bg-gradient-to-b from-slate-900/90 via-slate-900/40 to-slate-900/90 z-10 transition-opacity duration-500"></div>
            </div>
            
            <!-- Content -->
            <div class="relative z-20 d-flex flex-1 flex-col content-end">
              <h3 class="text-xl font-bold text-white mb-3 font-display tracking-tight transition-colors">{step.title}</h3>
              <p class="text-slate-300 text-sm leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
