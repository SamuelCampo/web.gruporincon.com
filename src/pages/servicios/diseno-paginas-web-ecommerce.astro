<script>
    (function () {
        const host = window.location.hostname;
        const isVE = host.includes("com.ve") || host.includes("localhost");
        const select = document.getElementById("presupuesto");
        const label = document.getElementById("budget-label");
        if (!select || !label) return;

        const options = isVE
            ? ["Menos de \$500", "\$500 a \$1.500", "Más de \$1.500"]
            : ["Menos de \$3M", "\$3M a \$7M", "Más de \$7M"];

        label.textContent = isVE
            ? "Presupuesto estimado (USD)"
            : "Presupuesto estimado (COP)";

        options.forEach(function (opt) {
            const el = document.createElement("option");
            el.value = opt;
            el.textContent = opt;
            el.className = "bg-zinc-900";
            select.appendChild(el);
        });
    })();
</script>
