---
import Layout from "../layouts/Layout.astro";

const values = [
  {
    name: "Innovación Práctica",
    description:
      "Usamos tecnologías top (React, AWS, Python, Laravel) pero siempre enfocadas en resolver problemas reales, no solo por moda.",
    icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  },
  {
    name: "Empatía Empresarial",
    description:
      "Entendemos tus dolores. Si nos pides una web, pensamos en cómo esa web te hará vender más y captar mejores leads.",
    icon: "M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5",
  },
  {
    name: "Agilidad",
    description:
      "Valoramos tu tiempo. Nuestros flujos de trabajo están optimizados para entregas rápidas sin sacrificar un solo píxel de calidad.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
  },
  {
    name: "Acompañamiento",
    description:
      "No te entregamos el código y desaparecemos. Nuestro soporte post-venta mensual garantiza que tu plataforma evolucione contigo.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
  },
];
---

<Layout
  title="Nosotros — Grupo Rincon"
  description="Más de una década transformando código en resultados. Conoce nuestro propósito, nuestros valores y por qué somos el aliado tecnológico ideal para tu PYME."
>
  <section
    class="pt-32 pb-16 lg:pt-40 lg:pb-24 bg-zinc-950 relative overflow-hidden"
  >
    <!-- Accent Radial Glow -->
    <div
      class="absolute top-[-20%] left-[-10%] w-[50%] h-[60%] rounded-full bg-amber-500/5 blur-[120px] pointer-events-none"
      aria-hidden="true"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl reveal">
        <h1
          class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-tight tracking-tight"
        >
          Más de una década <span
            class="bg-gradient-to-r from-blue-400 to-blue-800 bg-clip-text text-transparent"
            >transformando código en resultados</span
          >.
        </h1>
      </div>
    </div>
  </section>

  <section class="bg-zinc-950 py-16 lg:py-24 relative z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto reveal">
        <p class="text-base sm:text-lg text-zinc-400 leading-relaxed mb-6">
          En Grupo Rincon, no somos solo una agencia de desarrollo de software;
          somos tu departamento tecnológico aliado. Nacimos hace más de 10 años
          con una convicción clara: las pequeñas y medianas empresas merecen
          acceso a tecnología de primer nivel, sin procesos burocráticos ni un
          lenguaje incomprensible.
        </p>
        <p class="text-base sm:text-lg text-zinc-400 leading-relaxed mb-6">
          A lo largo de nuestra trayectoria, hemos ayudado a empresas en
          Venezuela, Colombia y otros 6 países a digitalizarse, vender más y
          optimizar su tiempo. Lo hacemos combinando ingeniería avanzada
          (nuestro lado técnico e innovador) con un trato humano, cercano y
          transparente.
        </p>
        <p class="text-base sm:text-lg text-white font-semibold">
          Más de 100 proyectos entregados en 8 países respaldan nuestro código.
        </p>
      </div>
    </div>
  </section>

  <section
    class="bg-zinc-900/10 border-y border-zinc-900/60 py-16 lg:py-24 relative overflow-hidden"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl mx-auto text-center reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white mb-6">
          Nuestro Propósito
        </h2>
        <p class="text-zinc-400 text-sm sm:text-base leading-relaxed">
          Queremos que dejes de preocuparte por servidores caídos, webs lentas o
          procesos manuales que te roban tiempo. Nuestro propósito es construir
          plataformas robustas, escalables y orientadas a la conversión, para
          que tú puedas enfocarte en lo que mejor sabes hacer: hacer crecer tu
          negocio.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-zinc-950 py-20 lg:py-28 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-16 lg:mb-20 reveal">
        <span
          class="text-xs font-bold text-blue-500 uppercase tracking-widest bg-blue-500/10 px-3.5 py-1.5 rounded-full"
          >Nuestros Valores</span
        >
        <h2 class="text-3xl sm:text-4xl font-black text-white mt-4">
          Lo que nos define (Nuestro ADN)
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {
          values.map((value, i) => (
            <div
              class="group glass-panel glass-panel-hover rounded-3xl p-8 lg:p-10 flex flex-col relative overflow-hidden reveal cursor-pointer"
              style={`animation-delay: ${i * 100}ms`}
            >
              <div class="w-12 h-12 bg-blue-500/10 border border-blue-500/20 rounded-2xl flex items-center justify-center mb-6 group-hover:border-blue-500/40 transition-colors duration-300">
                <svg
                  class="w-5 h-5 text-blue-500"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.2"
                    d={value.icon}
                  />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white mb-3 tracking-tight">
                {value.name}
              </h3>
              <p class="text-zinc-400 text-sm sm:text-base leading-relaxed">
                {value.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="bg-zinc-900/35 border-y border-zinc-900/60 py-20 lg:py-24 relative overflow-hidden"
  >
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 rounded-full bg-amber-500/3 blur-[120px] pointer-events-none"
      aria-hidden="true"
    >
    </div>

    <div
      class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 reveal"
    >
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white mb-6">
        La combinación perfecta entre talento local y alcance global
      </h2>
      <p
        class="text-zinc-400 text-sm sm:text-base leading-relaxed max-w-2xl mx-auto"
      >
        Nuestros dominios oficiales, gruporincon.com.ve y gruporincon.com.co,
        son el reflejo de nuestra esencia: entendemos a la perfección las
        dinámicas, retos y oportunidades del mercado local en Venezuela y
        Colombia, pero operamos con estándares de calidad internacionales.
      </p>
    </div>

    <section class="py-20 lg:py-24 text-center">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
        <a
          href="https://wa.me/584262590251"
          target="_blank"
          rel="noopener noreferrer"
          class="glow-btn cursor-pointer inline-flex items-center gap-2.5 bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-full text-sm font-bold tracking-wide transition-all duration-300"
        >
          <svg
            class="w-4 h-4"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          Escríbenos por WhatsApp
        </a>
      </div>
    </section>
  </section>
</Layout>
